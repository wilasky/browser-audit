{
  "manifest_version": 3,
  "name": "Browser Audit",
  "version": "0.1.0",
  "description": "Audita la configuración de tu navegador e inspecciona el comportamiento de scripts en tiempo real.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "optional_permissions": [
    "management",
    "privacy"
  ],

  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Browser Audit",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
